import numpy as np
import matplotlib.pyplot as plt
from scipy import stats



# Параметры биномиальной модели
S0 = 630.00                      # Начальная цена акции Татнефти
K = 750.00                       # Страйк опциона
T = 3                            # Горизонт моделирования (3 года)

R_list = np.array([0.14, 0.12, 0.105])   # Безрисковые ставки: 14%, 12%, 10.5%
u_list = np.array([1.2000, 1.2500, 1.3000])  # Множители роста
d_list = np.array([0.8500, 0.8200, 0.8000])  # Множители падения
p_u = np.array([0.68, 0.72, 0.75])  # Объективные вероятности роста
p_d = 1 - p_u                      # Объективные вероятности падения

# Цена опциона из биномиальной модели
V0 = 121.51                        # Справедливая цена европейского колл-опциона

print("=" * 80)
print("СТОХАСТИЧЕСКОЕ ДИНАМИЧЕСКОЕ ПРОГРАММИРОВАНИЕ")
print("Оптимистический сценарий - ПАО «Татнефть»")
print("=" * 80)
print(f"\nПараметры модели:")
print(f"  Начальная цена акции (S₀): {S0} руб.")
print(f"  Страйк опциона (K): {K} руб.")
print(f"  Цена опциона (V₀): {V0} руб.")
print(f"  Горизонт (T): {T} года")
print(f"  Безрисковые ставки (R): {R_list}")
print(f"  Множители роста (u): {u_list}")
print(f"  Множители падения (d): {d_list}")
print(f"  Объективные вероятности роста (pᵤ): {p_u}")

# ============================================================================
# РАСЧЕТ ПАРАМЕТРОВ ДЛЯ ДИНАМИЧЕСКОГО ПРОГРАММИРОВАНИЯ
# ============================================================================

# Ожидаемая доходность рискового актива
k = p_u * u_list + p_d * d_list

# Безрисковая доходность
r = 1 + R_list

print(f"\nОжидаемые доходности рискового актива (k): {k}")
print(f"Безрисковые доходности (1+R): {r}")
print(f"Премия за риск (k - r): {k - r}")

# Волатильность случайной компоненты
# σ_t = √(p(u-k)² + pᵈ(d-k)²)
w_std = np.sqrt(p_u * (u_list - k)**2 + p_d * (d_list - k)**2)

print(f"\nСтандартное отклонение случайной компоненты (σ_t): {w_std}")

# ============================================================================
# ПАРАМЕТРЫ ЧИСЛЕННОГО РЕШЕНИЯ
# ============================================================================

N_RUNS = 10                        # Количество прогонов для усреднения
MAX_LEVERAGE = 2.5                 # Максимальная доля рискового актива
N_MC = 5000                        # Количество симуляций Монте-Карло

# Сетка для динамического программирования
# V0 = 121.51, 
z_min = 20.0
z_max = 400.0
num_z = 500
z_grid = np.linspace(z_min, z_max, num_z)

# Сетка для управления
u_grid = np.linspace(0.0, MAX_LEVERAGE, 81)  # 81 точка от 0 до 2.5

DISTRIBUTIONS = ['normal', 'laplace', 'uniform']

print(f"\nПараметры численного решения:")
print(f"  Начальный капитал (V₀): {V0} руб.")
print(f"  Диапазон z_grid: [{z_min}, {z_max}]")
print(f"  Максимальное плечо: {MAX_LEVERAGE}")
print(f"  Количество симуляций: {N_MC}")

# ============================================================================
# ФУНКЦИИ ДЛЯ РАСПРЕДЕЛЕНИЙ
# ============================================================================

def get_params(dist_type, std_t):
    """
    Получение параметров распределения с одинаковым средним (0) и 
    стандартным отклонением (std_t)
    """
    if dist_type == 'normal':
        # Для нормального: σ = std_t
        return {'loc': 0.0, 'scale': std_t}
    
    elif dist_type == 'laplace':
        # Для Лапласа: Var = 2*scale² = std_t² → scale = std_t/√2
        return {'loc': 0.0, 'scale': std_t / np.sqrt(2)}
    
    elif dist_type == 'uniform':
        # Для равномерного: Var = (b-a)²/12 = std_t²
        # a = -√3·std_t, b = √3·std_t
        a = -np.sqrt(3) * std_t
        b = np.sqrt(3) * std_t
        return {'low': a, 'high': b}

def generate_w(dist_type, params, size):
    """Генерация случайных величин из заданного распределения"""
    if dist_type == 'normal':
        return np.random.normal(loc=params['loc'], scale=params['scale'], size=size)
    elif dist_type == 'laplace':
        return np.random.laplace(loc=params['loc'], scale=params['scale'], size=size)
    elif dist_type == 'uniform':
        return np.random.uniform(low=params['low'], high=params['high'], size=size)

# ============================================================================
# ИНИЦИАЛИЗАЦИЯ РЕЗУЛЬТАТОВ
# ============================================================================

avg_results = {dist: {
    'V0_expected': 0.0,
    'u_opt': np.zeros(T),
    'V': [np.zeros(num_z) for _ in range(T+1)],
    'policy': [np.zeros(num_z) for _ in range(T)]
} for dist in DISTRIBUTIONS}

all_results = {dist: [] for dist in DISTRIBUTIONS}

# ============================================================================
# ОСНОВНОЙ ЦИКЛ (N_RUNS прогонов)
# ============================================================================

for run in range(N_RUNS):
    np.random.seed(run)
    print(f"\n--- Прогон {run+1}/{N_RUNS} ---")
    
    for dist_type in DISTRIBUTIONS:
        # Генерация случайных компонент для всех шагов
        W = np.zeros((T, N_MC, len(u_grid)))
        for t in range(T):
            params = get_params(dist_type, w_std[t])
            w_col = generate_w(dist_type, params, (N_MC, 1))
            W[t] = np.tile(w_col, (1, len(u_grid)))
        
        # Инициализация функции ценности и политики
        V = [np.zeros(num_z) for _ in range(T+1)]
        policy = [np.zeros(num_z) for _ in range(T)]
        
        # Терминальное условие: V_T(z) = z
        V[T] = z_grid.copy()
        
        u_arr = u_grid.reshape(1, -1)
        
        # Обратная индукция от T-1 до 0
        for t in range(T-1, -1, -1):
            rt = r[t]
            kt = k[t]
            V_next = V[t+1]
            
            for i, z in enumerate(z_grid):
                # Эволюция капитала: z_{t+1} = z_t · (r_t + (k_t - r_t + w_t) · u_t)
                excess_return = (kt - rt) + W[t]
                z_next = z * (rt + excess_return * u_arr)
                
                # Ограничение: капитал не может быть отрицательным
                z_next = np.maximum(z_next, 0.0)
                
                # Интерполяция функции ценности на следующем шаге
                z_flat = z_next.ravel()
                V_interp = np.interp(z_flat, z_grid, V_next, left=0.0, right=V_next[-1])
                V_interp = V_interp.reshape(N_MC, len(u_grid))
                
                # Математическое ожидание
                expected = np.mean(V_interp, axis=0)
                
                # Оптимальное управление: u_t* = argmax E[V_{t+1}(z_{t+1})]
                best_idx = np.argmax(expected)
                V[t][i] = expected[best_idx]
                policy[t][i] = u_grid[best_idx]
        
        # Интерполяция для начального капитала V0
        V0_exp = np.interp(V0, z_grid, V[0])
        u_opt = np.array([np.interp(V0, z_grid, policy[t]) for t in range(T)])
        
        # Накопление результатов для усреднения
        avg_results[dist_type]['V0_expected'] += V0_exp / N_RUNS
        avg_results[dist_type]['u_opt'] += u_opt / N_RUNS
        
        for t_idx in range(T+1):
            avg_results[dist_type]['V'][t_idx] += V[t_idx] / N_RUNS
        for t_idx in range(T):
            avg_results[dist_type]['policy'][t_idx] += policy[t_idx] / N_RUNS
        
        all_results[dist_type].append({
            'V0_expected': V0_exp,
            'u_opt': u_opt,
            'V': V,
            'policy': policy
        })
        
        print(f"  {dist_type}: V₀_ожид = {V0_exp:.2f}, u_opt = {u_opt}")

