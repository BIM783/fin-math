# ============================================================================
# ГРАФИК 2: Плотности распределений
# ============================================================================

plt.figure(figsize=(10, 6))
x_plot = np.linspace(-1, 1, 1000)
std0 = w_std[0]

pdf_funcs = {
    'normal': lambda x, p: stats.norm.pdf(x, loc=p['loc'], scale=p['scale']),
    'laplace': lambda x, p: stats.laplace.pdf(x, loc=p['loc'], scale=p['scale']),
    'uniform': lambda x, p: stats.uniform.pdf(x, loc=p['low'], scale=p['high'] - p['low'])
}

line_styles = ['-', '--', '-.']

for i, dist_type in enumerate(DISTRIBUTIONS):
    params = get_params(dist_type, std0)
    pdf = pdf_funcs[dist_type](x_plot, params)
    plt.plot(x_plot, pdf, line_styles[i], lw=2, label=dist_type.capitalize())

plt.xlabel('Значение случайной компоненты w', fontsize=12)
plt.ylabel('Плотность распределения', fontsize=12)
